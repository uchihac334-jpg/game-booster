<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ Game Booster"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtRam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RAM tersedia: -"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnClearRam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bersihin RAM / Cache"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnDnd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aktifkan Game Mode"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnUsageAccess"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kasih Izin Usage Access (buat FPS)"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Monitor (CPU/Suhu/RAM)"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tampilkan di Overlay"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="4dp" />

    <CheckBox
        android:id="@+id/chkShowFps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FPS"
        android:textColor="#CCCCCC"
        android:checked="true" />

    <CheckBox
        android:id="@+id/chkShowCpu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CPU %"
        android:textColor="#CCCCCC"
        android:checked="true" />

    <CheckBox
        android:id="@+id/chkShowTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Suhu"
        android:textColor="#CCCCCC"
        android:checked="true" />

    <CheckBox
        android:id="@+id/chkShowRam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RAM"
        android:textColor="#CCCCCC"
        android:checked="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tanpa root: efek kill app terbatas, tapi DND &amp; monitor beneran jalan."
        android:textColor="#666666"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="24dp" />

</LinearLayout>
</ScrollView>
